*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text

# The plugin's own bundled assets must NOT live in Git LFS: GitHub release
# "Source code" zips ship LFS pointer files instead of the real binaries, which load
# as "package summary is invalid / corrupted". Keep these as normal git blobs so the
# distributed plugin works. (Host-project content above stays in LFS.)
Plugins/AssetsBridge/Content/**/*.uasset !filter !diff !merge -text
